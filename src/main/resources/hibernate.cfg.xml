<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "https://hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>

    <session-factory>

        <!-- ═══════════════ Database Connection ═══════════════ -->

        <property name="hibernate.connection.driver_class">
            com.mysql.cj.jdbc.Driver
        </property>

        <property name="hibernate.connection.url">
            jdbc:mysql://localhost:3306/fooddeliverydb?useSSL=false&amp;serverTimezone=UTC&amp;allowPublicKeyRetrieval=true
        </property>

        <!-- Change these if your MySQL credentials are different -->
        <property name="hibernate.connection.username">root</property>
        <property name="hibernate.connection.password">Sound@87888</property>

        <!-- ═══════════════ Connection Pool (basic) ════════════ -->
        <!-- Increase pool size in production or use c3p0/HikariCP -->
        <property name="hibernate.connection.pool_size">10</property>

        <!-- ═══════════════ Hibernate Dialect ═════════════════ -->
        <property name="hibernate.dialect">
            org.hibernate.dialect.MySQLDialect
        </property>

        <!-- ═══════════════ Schema Management ═════════════════ -->
        <!--
            Options:
              create        – drops and recreates all tables on startup (DEV only)
              create-drop   – creates on startup, drops on shutdown (testing)
              update        – adds missing columns/tables without dropping data (DEV/STAGING)
              validate      – validates schema matches entities, throws if mismatch (PRODUCTION)
              none          – do nothing (PRODUCTION when using Flyway/Liquibase)

            Use 'update' during development, 'validate' or 'none' in production.
        -->
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- ═══════════════ SQL Logging ════════════════════════ -->
        <!-- Set to false in production to avoid log noise -->
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>
        <property name="hibernate.use_sql_comments">true</property>

    </session-factory>

</hibernate-configuration>